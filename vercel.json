{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/main.py": {
      "runtime": "vercel-python@4.5.0"
    }
  },
  "builds": [
    { "src": "api/main.py", "use": "@vercel/python" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/main", "destination": "/api/main.py" }
  ]
}
